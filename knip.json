{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"workspaces": {
		".": {
			"entry": [
				"src/routes/**/+{page,layout,server,error}.{ts,svelte}",
				"src/convex/**/*.ts",
				"!src/convex/_generated/**",
				"e2e/**/*.ts"
			],
			"project": ["src/**/*.{ts,svelte}", "e2e/**/*.ts"]
		},
		"packages/mcp-server": {
			"project": ["src/**/*.ts"]
		},
		"packages/living-ui-runtime": {
			"project": ["src/**/*.{ts,tsx}"],
			"ignoreDependencies": ["react-native", "react-native-reanimated"]
		}
	},
	"ignoreIssues": {
		"packages/living-ui-runtime/src/react-native.tsx": ["duplicates"]
	},
	"ignoreExportsUsedInFile": true,
	"ignoreDependencies": ["tailwindcss", "vercel"],
	"svelte": true,
	"vitest": true,
	"vite": true
}
