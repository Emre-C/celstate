{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"entry": [
		"src/routes/**/+{page,layout,server,error}.{ts,svelte}",
		"src/convex/**/*.ts",
		"!src/convex/_generated/**"
	],
	"project": ["src/**/*.{ts,svelte}"],
	"ignoreExportsUsedInFile": true,
	"ignoreDependencies": ["tailwindcss"],
