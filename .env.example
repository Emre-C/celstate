# Copy to `.env.local` and adjust. Never commit real secrets.
# Full contract: docs/runbooks/PUBLIC-ENV-CHECKLIST.md

# This SvelteKit app's own origin (canonical redirects, auth return URLs, and public /mcp endpoint).
PUBLIC_SITE_URL=http://localhost:5173

# Clerk Auth (SvelteKit server/client plus Convex JWT validation).
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
PUBLIC_CLERK_SIGN_IN_URL=/auth
PUBLIC_CLERK_SIGN_UP_URL=/auth
PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app

# Error monitoring (omit DSNs locally to stay silent).
SENTRY_DSN=
PUBLIC_SENTRY_DSN=

# Convex deployment the browser talks to (`*.convex.cloud`). Must match `pnpm exec convex dev` / `convex deploy` target.
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Optional. Only when PUBLIC_CONVEX_URL is a loopback URL (local Convex) — same logical deployment’s HTTPS site origin.
# PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# PostHog (leave key empty to disable; names must exist for production builds — use placeholders in CI).
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# PostHog project id (numeric) — used by growth CLI (`pnpm growth:*`) and local HogQL; find it in PostHog Project Settings.
# Not imported by the SvelteKit app.
POSTHOG_PROJECT_ID=

# Personal API key (phx_…) — growth CLI only. Never expose to the client.
POSTHOG_PERSONAL_API_KEY=

# Optional. PostHog app origin for API calls; default https://us.posthog.com
# POSTHOG_APP_HOST=

# Animation media worker. Secret must also be configured in Convex via Doppler.
# ANIMATION_WORKER_SECRET=
