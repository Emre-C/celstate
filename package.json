{
	"name": "celstate",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"dev": "concurrently \"vite dev\" \"pnpm exec convex dev\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:auth": "vitest run scripts/auth-canary-probe.test.ts src/convex/users.provisioning.test.ts src/lib/server/auth-alerts.test.ts src/lib/server/response.test.ts src/lib/server/canonical-site.test.ts src/lib/auth/protected-session.test.ts src/lib/server/auth-guard.test.ts src/lib/server/authkit-guard.test.ts src/lib/server/access-token-response.test.ts src/lib/production-confidence.test.ts",
		"check:stripe-env": "tsx scripts/check-stripe-env.ts",
		"check:posthog-env": "tsx scripts/check-posthog-env.ts",
		"check:growth-tooling": "tsx scripts/growth-ops.ts check",
		"check:convex-auth": "tsx scripts/check-local-convex-auth.ts",
		"check:public-env": "tsx scripts/check-public-env.ts",
		"check:kit-server-env": "tsx scripts/check-kit-server-env.ts",
		"verify:doppler-kit-env": "node scripts/verify-doppler-kit-env.mjs",
		"check:ui-contracts": "tsx scripts/check-jsonld-head-pattern.ts",
		"check:purchase-observability": "pnpm check:stripe-env && pnpm check:posthog-env",
		"release:production": "node scripts/release-production.mjs",
		"verify:production": "tsx scripts/production-verification.ts",
		"animation-worker": "tsx scripts/animation-worker.ts",
		"animation-worker:once": "tsx scripts/animation-worker.ts --once",
		"animation-worker:report": "tsx scripts/animation-worker-report.ts",
		"transparent-animation-spike": "tsx scripts/transparent-animation-spike.ts",
		"reset-qa": "tsx scripts/reset-qa.ts",
		"growth:list": "tsx scripts/growth-ops.ts list",
		"growth:scaffold": "tsx scripts/growth-ops.ts scaffold",
		"growth:snapshot": "tsx scripts/growth-ops.ts snapshot",
		"growth:annotate": "tsx scripts/growth-ops.ts annotate",
		"secrets:rotate": "node scripts/secrets/rotate.mjs --project=celstate --config=prd",
		"secrets:rotate:dev": "node scripts/secrets/rotate.mjs --project=celstate --config=dev",
		"secrets:rotate-gcp": "node scripts/secrets/gcp-rotate-sa-key.mjs",
		"secrets:diff": "node scripts/secrets/diff-convex-vs-doppler.mjs",
		"secrets:sync:convex": "node scripts/secrets/sync.mjs --target=convex --env=prod --project=celstate --config=prd",
		"secrets:sync:convex:dev": "node scripts/secrets/sync.mjs --target=convex --env=dev --project=celstate --config=dev",
		"secrets:sync:vercel": "node scripts/secrets/sync.mjs --target=vercel --env=production --project=celstate --config=prd",
		"secrets:sync:vercel:preview": "node scripts/secrets/sync.mjs --target=vercel --env=preview --project=celstate --config=prd",
		"secrets:sync:gh": "node scripts/secrets/sync.mjs --target=github-actions --secrets=VERIFICATION_RUNNER_SECRET --project=celstate --config=prd",
		"knip": "knip",
		"knip:fix": "knip --fix",
		"dupcheck": "jscpd src/",
		"lint:ts": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"scripts/**/*.mjs\" \"e2e/**/*.ts\" \"playwright.config.ts\"",
		"typecheck:tsc": "tsc --noEmit",
		"test:e2e": "playwright test",
		"test:e2e:build": "cross-env PUBLIC_SITE_URL=http://127.0.0.1:4174 vite build",
		"verify": "cross-env PUBLIC_SITE_URL=http://127.0.0.1:4174 pnpm run verify:inner",
		"verify:inner": "pnpm check:public-env && pnpm check:ui-contracts && pnpm check && pnpm typecheck:tsc && pnpm knip && pnpm dupcheck && pnpm lint:ts && pnpm test && pnpm build && pnpm test:e2e"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"concurrently": "^9.2.0",
		"convex-test": "^0.0.50",
		"cross-env": "^10.1.0",
		"eslint": "9.39.0",
		"jscpd": "^4.0.9",
		"knip": "^6.7.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.6",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "8.59.0",
		"vercel": "50.37.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@convex-dev/stripe": "^0.1.3",
		"@google/genai": "^1.43.0",
		"@mmailaender/convex-svelte": "^0.17.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@posthog/convex": "^0.1.13",
		"@sentry/sveltekit": "^10.45.0",
		"@tailwindcss/vite": "^4.2.1",
		"@workos/authkit-sveltekit": "^0.3.0",
		"convex": "^1.38.0",
		"posthog-js": "^1.363.1",
		"sharp": "^0.34.5",
		"stripe": "^20.4.1",
		"tailwindcss": "^4.2.1",
		"zod": "^3.25.76"
	}
}
