{
	"name": "celstate",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.32.0",
	"scripts": {
		"dev": "concurrently \"vite dev\" \"pnpm exec convex dev\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/pngjs": "^6.0.5",
		"concurrently": "^9.0.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.11.1",
		"@convex-dev/stripe": "^0.1.3",
		"@google/genai": "^1.43.0",
		"@mmailaender/convex-better-auth-svelte": "^0.6.2",
		"@mmailaender/convex-svelte": "^0.17.0",
		"@tailwindcss/vite": "^4.2.1",
		"better-auth": "1.5.5",
		"convex": "^1.32.0",
		"pngjs": "^7.0.0",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.1"
	}
}
