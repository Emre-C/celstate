{
	"name": "celstate",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"dev": "concurrently \"vite dev\" \"pnpm exec convex dev\"",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:auth": "vitest run scripts/auth-canary-probe.test.ts src/lib/server/auth-proxy.test.ts src/lib/server/auth-alerts.test.ts src/lib/server/response.test.ts src/lib/auth-client.test.ts src/lib/server/canonical-site.test.ts src/lib/auth/protected-app.test.ts src/lib/server/auth-guard.test.ts src/lib/server/auth.test.ts src/lib/auth/config.test.ts",
		"check:stripe-env": "tsx scripts/check-stripe-env.ts",
		"check:posthog-env": "tsx scripts/check-posthog-env.ts",
		"check:growth-tooling": "tsx scripts/growth-ops.ts check",
		"check:convex-auth": "tsx scripts/check-local-convex-auth.ts",
		"check:public-env": "tsx scripts/check-public-env.ts",
		"check:ui-contracts": "tsx scripts/check-jsonld-head-pattern.ts",
		"check:purchase-observability": "pnpm check:stripe-env && pnpm check:posthog-env",
		"verify:production": "tsx scripts/production-verification.ts",
		"growth:list": "tsx scripts/growth-ops.ts list",
		"growth:scaffold": "tsx scripts/growth-ops.ts scaffold",
		"growth:snapshot": "tsx scripts/growth-ops.ts snapshot",
		"growth:annotate": "tsx scripts/growth-ops.ts annotate",
		"knip": "knip",
		"knip:fix": "knip --fix",
		"dupcheck": "jscpd src/",
		"lint:ts": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" \"scripts/**/*.mjs\" \"e2e/**/*.ts\" \"playwright.config.ts\"",
		"typecheck:tsc": "tsc --noEmit",
		"test:e2e": "playwright test",
		"test:e2e:build": "cross-env PUBLIC_SITE_URL=http://127.0.0.1:4174 vite build",
		"verify": "cross-env PUBLIC_SITE_URL=http://127.0.0.1:4174 pnpm run verify:inner",
		"verify:inner": "pnpm check:public-env && pnpm check:ui-contracts && pnpm check && pnpm typecheck:tsc && pnpm knip && pnpm dupcheck && pnpm lint:ts && pnpm test && pnpm build && pnpm test:e2e"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"concurrently": "^9.0.0",
		"convex-test": "^0.0.38",
		"cross-env": "^10.1.0",
		"eslint": "9.39.0",
		"jscpd": "^4.0.8",
		"knip": "^6.0.5",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "8.47.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@convex-dev/better-auth": "^0.11.1",
		"@convex-dev/stripe": "^0.1.3",
		"@google/genai": "^1.43.0",
		"@mmailaender/convex-better-auth-svelte": "^0.6.2",
		"@mmailaender/convex-svelte": "^0.17.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@posthog/convex": "^0.1.13",
		"@sentry/sveltekit": "^10.45.0",
		"@tailwindcss/vite": "^4.2.1",
		"better-auth": "1.6.0",
		"convex": "^1.33.1",
		"posthog-js": "^1.363.1",
		"sharp": "^0.34.5",
		"stripe": "^20.4.1",
		"tailwindcss": "^4.2.1",
		"zod": "^3.25.76"
	}
}
